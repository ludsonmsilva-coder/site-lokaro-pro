{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/html/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "lokaro.com.br" }],
      "destination": "/br.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.lokaro.com.br" }],
      "destination": "/br.html"
    }
  ]
}